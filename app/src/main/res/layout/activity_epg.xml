<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101010"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Top info area (simple placeholder like Tivimate) -->
    <LinearLayout
        android:id="@+id/topInfo"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:orientation="horizontal"
        android:background="#181818"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:background="#222222" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/tvProgramTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Title"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvProgramTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03:00 - 04:00"
                android:textColor="#BBBBBB"
                android:textSize="14sp"
                android:layout_marginTop="6dp" />

            <ProgressBar
                android:id="@+id/pbNow"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="420dp"
                android:layout_height="6dp"
                android:layout_marginTop="10dp"
                android:progress="35" />

            <TextView
                android:id="@+id/tvProgramDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description..."
                android:textColor="#DDDDDD"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:maxLines="3" />
        </LinearLayout>
    </LinearLayout>

    <!-- Time header -->
    <FrameLayout
        android:id="@+id/timeHeaderHost"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="#121212"
        app:layout_constraintTop_toBottomOf="@id/topInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- left spacer equal to channels column width -->
        <View
            android:id="@+id/leftSpacer"
            android:layout_width="150dp"
            android:layout_height="match_parent" />

        <HorizontalScrollView
            android:id="@+id/hsvTimeHeader"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="150dp"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/timeHeaderContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />
        </HorizontalScrollView>
    </FrameLayout>

    <!-- Left channels column -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChannels"
        android:layout_width="150dp"
        android:layout_height="0dp"
        android:background="#141414"
        app:layout_constraintTop_toBottomOf="@id/timeHeaderHost"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Rows (each row scrolls horizontally; we sync them) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRows"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#101010"
        app:layout_constraintTop_toBottomOf="@id/timeHeaderHost"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/rvChannels"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
