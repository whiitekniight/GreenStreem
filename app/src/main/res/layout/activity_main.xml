<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tivimate_background"
    tools:context=".MainActivity">

    <!-- Container for Video Player -->
    <FrameLayout
        android:id="@+id/playerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:resize_mode="fill" />
    </FrameLayout>

    <!-- TiviMate Style Overlay Layer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/epgOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/tivimate_overlay_semi_transparent"
        android:visibility="gone">

        <!-- 1. Main Nav Rail (Far Left, Full Height) -->
        <LinearLayout
            android:id="@+id/navRail"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@color/tivimate_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView android:id="@+id/navSearch"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Search"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navTv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="TV"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navMovies"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Movies"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navSeries"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="TV Series"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusDown="@+id/navSettings" />

            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:focusable="false" />

            <TextView android:id="@+id/navSettings"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Settings"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusUp="@+id/navSeries"
                android:nextFocusDown="@+id/navExit" />

            <TextView android:id="@+id/navExit"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Exit"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusUp="@+id/navSettings" />
        </LinearLayout>

        <!-- Top Info Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topInfo"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:background="@color/tivimate_background"
            android:padding="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent">

            <FrameLayout
                android:id="@+id/videoPreviewBox"
                android:layout_width="254dp"
                android:layout_height="140dp"
                android:background="#000000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toStartOf="@id/ivFavoriteStar"
                app:layout_constraintStart_toEndOf="@id/videoPreviewBox"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvProgramTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/tivimate_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="Expedition Files" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProgramTimeRange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/tivimate_text_secondary"
                        android:textSize="11sp"
                        tools:text="03:00 - 04:00 PM" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="1dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:background="@color/tivimate_text_secondary" />

                    <TextView
                        android:id="@+id/tvProgramDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/tivimate_text_secondary"
                        android:textSize="11sp"
                        tools:text="8 min" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgramDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/tivimate_text_primary"
                    android:textSize="10sp"
                    tools:text="Josh Gates steps into the past to examine unsolved mysteries..." />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivFavoriteStar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/tivimate_accent_green" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Main Content Area with Categories and EPG -->
        <LinearLayout
            android:id="@+id/mainContentArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/rvRecentChannels"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 2. Categories (Groups) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="180dp"
                android:layout_height="match_parent"
                android:background="@color/tivimate_surface"
                android:paddingTop="8dp"
                android:visibility="gone" />

            <!-- Right Panel: Time Ruler + Grid -->
            <LinearLayout
                android:id="@+id/rightPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Time Ruler Header -->
                <HorizontalScrollView
                    android:id="@+id/hsvTimeRuler"
                    android:layout_width="match_parent"
                    android:layout_height="24dp"
                    android:background="#0A0A0A"
                    android:scrollbars="none"
                    android:overScrollMode="never">

                    <LinearLayout
                        android:id="@+id/timeRulerContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="220dp" />
                </HorizontalScrollView>

                <!-- 3. EPG Grid (Channels) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEpg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/tivimate_background" />
            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentChannels"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:background="#0F1218"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/topInfo"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Fixed Program Progress Bar -->
        <ProgressBar
            android:id="@+id/pbProgramProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:progress="0"
            android:progressDrawable="@android:drawable/progress_horizontal"
            app:layout_constraintTop_toBottomOf="@id/rvRecentChannels"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/zapBar"
        android:layout_width="0dp"
        android:layout_height="86dp"
        android:layout_marginStart="90dp"
        android:layout_marginEnd="90dp"
        android:layout_marginBottom="24dp"
        android:background="@color/tivimate_overlay_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapPrev"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapPrev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapCurrent"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapCurrent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapNext"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
