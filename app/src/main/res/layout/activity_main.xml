<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tivimate_background"
    tools:context=".MainActivity">

    <!-- Container for Video Player -->
    <FrameLayout
        android:id="@+id/playerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:use_controller="false"
            app:resize_mode="fill"
            app:shutter_background_color="@android:color/transparent"
            app:surface_type="texture_view" />
    </FrameLayout>

    <!-- TiviMate Style Overlay Layer -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/epgOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/tivimate_overlay_semi_transparent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:visibility="gone">

        <!-- 1. Main Nav Rail (Far Left, Full Height) -->
        <LinearLayout
            android:id="@+id/navRail"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@color/tivimate_background"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView android:id="@+id/navSearch"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Search"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navTv"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="TV"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navMovies"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Movies"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg" />

            <TextView android:id="@+id/navSeries"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="TV Series"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusDown="@+id/navSettings" />

            <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:focusable="false" />

            <TextView android:id="@+id/navSettings"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Settings"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusUp="@+id/navSeries"
                android:nextFocusDown="@+id/navExit" />

            <TextView android:id="@+id/navExit"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" android:text="Exit"
                android:textColor="@color/tivimate_text_primary" android:textSize="16sp"
                android:gravity="center" android:padding="12dp"
                android:focusable="true" android:background="@drawable/selector_button_bg"
                android:nextFocusUp="@+id/navSettings" />
        </LinearLayout>

        <!-- Top Info Area -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topInfo"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:background="@color/tivimate_background"
            android:padding="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/vodBackdropGuide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_percent="0.46" />

            <ImageView
                android:id="@+id/ivVodBackdrop"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:alpha="0.92"
                android:background="#000000"
                android:scaleType="centerCrop"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/vodBackdropGuide"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/vVodBackdropFeather"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/vod_backdrop_feather"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/ivVodBackdrop"
                app:layout_constraintEnd_toEndOf="@id/ivVodBackdrop"
                app:layout_constraintStart_toStartOf="@id/ivVodBackdrop"
                app:layout_constraintTop_toTopOf="@id/ivVodBackdrop" />

            <View
                android:id="@+id/vVodBackdropShade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="#8C12161D"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <FrameLayout
                android:id="@+id/videoPreviewBox"
                android:layout_width="254dp"
                android:layout_height="140dp"
                android:background="#000000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivVodPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.92"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <androidx.media3.ui.PlayerView
                    android:id="@+id/previewPlayerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:use_controller="false"
                    app:resize_mode="fill"
                    app:shutter_background_color="@android:color/transparent"
                    app:surface_type="texture_view" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/libraryInfoPanel"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="18dp"
                android:gravity="top"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/vodBackdropGuide"
                app:layout_constraintStart_toEndOf="@id/videoPreviewBox"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/tvProgramTitleLarge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:textColor="@color/tivimate_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="Expedition Files" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvProgramTimeRange"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/tivimate_text_secondary"
                        android:textSize="12sp"
                        tools:text="03:00 - 04:00 PM" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="1dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="5dp"
                        android:background="@color/tivimate_text_secondary" />

                    <TextView
                        android:id="@+id/tvProgramDuration"
                        android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/tivimate_text_secondary"
                    android:textSize="12sp"
                        tools:text="8 min" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgramDescription"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="4dp"
                    android:includeFontPadding="false"
                    android:maxLines="30"
                    android:textColor="@color/tivimate_text_primary"
                    android:textSize="12sp"
                    tools:text="Josh Gates steps into the past to examine unsolved mysteries..." />
            </LinearLayout>

            <ImageView
                android:id="@+id/ivFavoriteStar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_favorite_star"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <HorizontalScrollView
                android:id="@+id/vodTopActionsScroller"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="18dp"
                android:fillViewport="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:id="@+id/vodTopActionsBar"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Main Content Area with Categories and EPG -->
        <LinearLayout
            android:id="@+id/mainContentArea"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/rvRecentChannels"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- 2. Categories (Groups) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="180dp"
                android:layout_height="match_parent"
                android:background="@color/tivimate_surface"
                android:paddingTop="8dp"
                android:visibility="gone" />

            <!-- Right Panel: Time Ruler + Grid -->
            <FrameLayout
                android:id="@+id/rightPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="vertical">

                    <!-- Time Ruler Header -->
                    <HorizontalScrollView
                        android:id="@+id/hsvTimeRuler"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:background="#0A0A0A"
                        android:scrollbars="none"
                        android:overScrollMode="never">

                        <LinearLayout
                            android:id="@+id/timeRulerContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="220dp" />
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/tvLibraryCategoryCount"
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:background="#00000000"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:textColor="@color/tivimate_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="Action • 243 movies" />

                    <HorizontalScrollView
                        android:id="@+id/vodInlineActionsScroller"
                        android:layout_width="match_parent"
                        android:layout_height="76dp"
                        android:background="@color/tivimate_background"
                        android:fillViewport="true"
                        android:overScrollMode="never"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:scrollbars="none"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/vodInlineActionsBar"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <!-- 3. EPG Grid (Channels) -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEpg"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/tivimate_background"
                        android:clipChildren="true"
                        android:clipToPadding="true"
                        android:paddingTop="6dp"
                        android:paddingBottom="14dp" />
                </LinearLayout>

                <View
                    android:id="@+id/nowTimeLine"
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="#50A8D8FF"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvRecentChannels"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:background="#0F1218"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/topInfo"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Fixed Program Progress Bar -->
        <ProgressBar
            android:id="@+id/pbProgramProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:progress="0"
            android:progressDrawable="@drawable/progress_bar_program"
            app:layout_constraintTop_toBottomOf="@id/rvRecentChannels"
            app:layout_constraintStart_toEndOf="@id/navRail"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/zapBar"
        android:layout_width="0dp"
        android:layout_height="86dp"
        android:layout_marginStart="90dp"
        android:layout_marginEnd="90dp"
        android:layout_marginBottom="24dp"
        android:background="@color/tivimate_overlay_dark"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapPrev"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapPrev"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapCurrent"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapCurrent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivZapNext"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_report_image" />

            <TextView
                android:id="@+id/tvZapNext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/movieControlsBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="96dp"
        android:layout_marginEnd="96dp"
        android:layout_marginBottom="34dp"
        android:background="@color/tivimate_overlay_dark"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="8dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMovieControlsTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/tivimate_text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Apex - 2026" />

            <TextView
                android:id="@+id/tvMovieControlsPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="15sp"
                tools:text="00:14:22 / 01:35:00" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/movieProgressRow"
            android:layout_width="match_parent"
            android:layout_height="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvMovieProgressStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:textColor="@color/tivimate_text_primary"
                android:textSize="13sp"
                tools:text="14:22" />

            <ProgressBar
                android:id="@+id/pbMovieControlsProgress"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:max="1000"
                android:progress="0"
                android:progressDrawable="@drawable/progress_bar_program" />

            <TextView
                android:id="@+id/tvMovieProgressEnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="@color/tivimate_text_secondary"
                android:textSize="13sp"
                tools:text="1:35:00" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvMovieControlsDropHint"
            android:layout_width="match_parent"
            android:layout_height="18dp"
            android:gravity="center"
            android:text="v"
            android:textColor="@color/tivimate_accent_green"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/movieControlsButtons"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnMoviePlayPause"
                style="@style/GreenStreemMovieControlButton"
                android:text="Pause" />

            <TextView
                android:id="@+id/btnMovieAudio"
                style="@style/GreenStreemMovieControlButton"
                android:text="Audio Track" />

            <TextView
                android:id="@+id/btnMovieSubtitles"
                style="@style/GreenStreemMovieControlButton"
                android:text="Subtitles" />

            <TextView
                android:id="@+id/btnMovieAspect"
                style="@style/GreenStreemMovieControlButton"
                android:text="Display" />

            <TextView
                android:id="@+id/btnMovieOffset"
                style="@style/GreenStreemMovieControlButton"
                android:text="Audio Sync" />

            <TextView
                android:id="@+id/btnMovieSleep"
                style="@style/GreenStreemMovieControlButton"
                android:text="Sleep" />

            <TextView
                android:id="@+id/btnMovieSettings"
                style="@style/GreenStreemMovieControlButton"
                android:text="Playback" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
